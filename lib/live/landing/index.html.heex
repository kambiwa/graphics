</section>

<!-- QUOTE GENERATOR -->
<section class="quote-section" id="quote">
  <div class="quote-inner">
    <p class="section-eyebrow">Instant Quote</p>
    <h2 class="section-title" style="color:var(--white);">GET YOUR<br>ESTIMATE</h2>

    <form
      id="quoteForm"
      class="quote-form"
      phx-change="calculate_quote"
    >
      <div class="form-field">
        <label>Service Type</label>
        <select name="service_type">
          <option value="">Select Service</option>
          <option value="wedding"    selected={@quote_service_type == "wedding"}>Wedding</option>
          <option value="graduation" selected={@quote_service_type == "graduation"}>Graduation</option>
          <option value="portrait"   selected={@quote_service_type == "portrait"}>Portrait</option>
          <option value="corporate"  selected={@quote_service_type == "corporate"}>Corporate</option>
          <option value="event"      selected={@quote_service_type == "event"}>Event</option>
        </select>
      </div>

      <div class="form-field">
        <label>Hours</label>
        <input
          type="number"
          name="hours"
          min="1"
          value={@quote_hours}
          phx-debounce="300"
        />
      </div>

      <div class="addon-row">
        <label class="addon-check">
          <input
            type="checkbox"
            name="drone_coverage"
            value="true"
            checked={@quote_drone}
          />
          <span>+ Drone Coverage (K1,200)</span>
        </label>

        <label class="addon-check">
          <input
            type="checkbox"
            name="videography"
            value="true"
            checked={@quote_video}
          />
          <span>+ Videography (K1,800)</span>
        </label>
      </div>

      <div class="quote-result">
        <p>Estimated Total</p>
        <div class="quote-price">
          K <%= if Decimal.compare(@quote_total, Decimal.new("0")) == :eq do %>
            0
          <% else %>
            <%= @quote_total |> Decimal.to_string() |> format_price() %>
          <% end %>
        </div>
      </div>

      <%= if Decimal.compare(@quote_total, Decimal.new("0")) == :gt do %>
          <button
            type="button"
            class="btn-fill"
            style="width:100%;border-radius:10px;padding:0.9rem;margin-top:1rem;"
            phx-click="save_quotation"
          >
            Save & Download PDF
          </button>
        <% end %>

        <%= if assigns[:saved_quotation_number] do %>
          <p style="font-size:0.72rem;text-align:center;color:rgba(255,255,255,0.5);margin-top:0.75rem;">
            Saved as <strong style="color:#E05C3A;"><%= @saved_quotation_number %></strong>
            · <a href={"/quotations/#{@saved_quotation_id}/pdf"} style="color:#E05C3A;" target="_blank">Download again</a>
          </p>
        <% end %>
    </form>
  </div>
</section>

<!-- BOOKING -->
<section class="booking-section" id="booking">
  <div class="booking-inner">
    <p class="section-eyebrow">Booking</p>
    <h2 class="section-title">BOOK YOUR<br><em>Session</em></h2>
    <p class="section-body">Ready to create something beautiful? Fill in your details and we'll be in touch within 24 hours.</p>

    <%= if @submitted_booking do %>
      <div style="background:#FAF9F7;border:0.5px solid rgba(26,26,24,0.1);border-radius:14px;padding:2.5rem;text-align:center;">
        <div style="width:52px;height:52px;border-radius:50%;background:#d1fae5;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
          <i class="ti ti-check" style="font-size:24px;color:#065f46;"></i>
        </div>
        <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:0.08em;color:#1a1a18;margin:0 0 0.5rem;">Booking Received!</h3>
        <p style="font-size:0.88rem;color:#6b6b67;margin:0 0 1.5rem;">Thanks, <strong><%= @booking_name %></strong>. We'll be in touch within 24 hours.</p>
        <button
          type="button"
          class="btn-fill"
          style="border-radius:10px;padding:0.75rem 2rem;"
          phx-click="reset_booking"
        >
          Submit Another
        </button>
      </div>
    <% else %>
      <.form
            for={@booking_form}
            phx-submit="submit_booking"
            phx-change="validate_booking"
            id="bookingForm"
            class="booking-form"
          >
            <div class="booking-field">
              <label>Full Name</label>
              <.input field={@booking_form[:client_name]} type="text" placeholder="Your full name" />
            </div>
            <div class="booking-field">
              <label>Email</label>
              <.input field={@booking_form[:email]} type="email" placeholder="your@email.com" />
            </div>
            <div class="booking-field">
              <label>Phone Number</label>
              <.input field={@booking_form[:phone_number]} type="tel" placeholder="+260 XXX XXX XXX" />
            </div>
            <div class="booking-field">
              <label>Event Type</label>
              <.input
                field={@booking_form[:service_type]}
                type="select"
                options={[
                  {"-- Select type --", ""},
                  {"Wedding", "wedding"},
                  {"Graduation", "graduation"},
                  {"Portrait", "portrait"},
                  {"Corporate", "corporate"},
                  {"Event", "event"}
                ]}
              />
            </div>
            <div class="booking-field">
              <label>Event Date</label>
              <.input field={@booking_form[:event_date]} type="date" />
            </div>
            <div class="booking-field">
              <label>Location</label>
              <.input field={@booking_form[:location]} type="text" placeholder="Event location" />
            </div>
            <div class="booking-field full">
              <label>Tell Us About Your Event</label>
              <.input
                field={@booking_form[:notes]}
                type="textarea"
                placeholder="Describe your event, special requirements…"
              />
            </div>
            <div class="booking-field full" style="margin-top:0.5rem;">
              <button class="btn-fill" type="submit" style="width:100%;border-radius:10px;padding:1rem;">
                Submit Booking
              </button>
            </div>
          </.form>
    <% end %>
  </div>
</section>

