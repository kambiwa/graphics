<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow fade-up d1">Jaguar Photography · Lusaka, Zambia</p>
    <h1 class="hero-title fade-up d2">
      CAPTURING<br><em>Timeless</em><br>MOMENTS
    </h1>
    <p class="hero-desc fade-up d3">
      Professional photography for weddings, graduations, corporate events, portraits, and unforgettable memories across Zambia.
    </p>
    <div class="hero-actions fade-up d3">
      <a href="#booking" class="btn-fill">Book a Session</a>
      <a href="#quote" class="btn-outline">Get a Quote</a>
    </div>

    <div class="hero-stats-badge fade-up d3" style="position:relative;bottom:auto;left:auto;margin-top:3rem;width:fit-content;">
      <div class="stat-item">
        <h4>500+</h4>
        <p>Projects</p>
      </div>
      <div class="stat-item">
        <h4>100+</h4>
        <p>Clients</p>
      </div>
      <div class="stat-item">
        <h4>5+</h4>
        <p>Years</p>
      </div>
    </div>

    <div class="hero-case-badge fade-up d3" style="position:relative;bottom:auto;left:auto;margin-top:1rem;width:fit-content;">
      <div class="avatar-stack">
        <span>TM</span><span>AN</span><span>BK</span>
      </div>
      <div class="case-label">
        <strong>Happy Clients</strong>
        <a href="#testimonials">View Testimonials →</a>
      </div>
    </div>
  </div>

  <div class="hero-right">
      <img
        src="/images/photography/photographer.png"
        alt="Photographer"
        class="hero-img"
      />

      <a href="#portfolio" class="accent-circle">
        <span>SEE<br>HOW IT<br>WORKS</span>
      </a>

      <div class="news-ticker">
        <span class="ticker-label">Latest</span>
        <span class="ticker-text">Now booking weddings for 2026 season</span>
      </div>
    </div>
    </section>

