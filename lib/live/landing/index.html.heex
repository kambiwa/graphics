        <p class="portfolio-sub">Class of 2024</p>
      </div>
      <span class="portfolio-label">Graduation</span>
    </div>

    <div class="portfolio-item p3">
      <img src="/images/photography/meet.jpg" alt="Corporate event photography" class="portfolio-img" />
      <div class="portfolio-overlay">
        <span class="portfolio-num">03</span>
        <p class="portfolio-title">CORPORATE</p>
        <p class="portfolio-sub">Events & conferences</p>
      </div>
      <span class="portfolio-label">Corporate</span>
    </div>

    <div class="portfolio-item p4">
      <img src="/images/photography/black.jpg" alt="Portrait photography" class="portfolio-img" />
      <div class="portfolio-overlay">
        <span class="portfolio-num">04</span>
        <p class="portfolio-title">PORTRAITS</p>
        <p class="portfolio-sub">Personal & family</p>
      </div>
      <span class="portfolio-label">Portraits</span>
    </div>

    <div class="portfolio-item p5">
      <img src="/images/photography/pproduct.jpg" alt="Commercial product photography" class="portfolio-img" />
      <div class="portfolio-overlay">
        <span class="portfolio-num">05</span>
        <p class="portfolio-title">COMMERCIAL</p>
        <p class="portfolio-sub">Product & branding</p>
      </div>
      <span class="portfolio-label">Commercial</span>
    </div>

